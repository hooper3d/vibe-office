{
  "name": "vibe-office",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "ci": "node scripts/run-release-check.mjs && npm run typecheck && npm run typecheck:unused && npm test && npm run build && npm run regression:providers:list",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node scripts/run-service-tests.mjs",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:unused": "tsc -p tsconfig.app.json --noEmit --noUnusedLocals --noUnusedParameters false",
    "release:check": "node scripts/run-release-check.mjs && npm test && npm run build && npm run smoke:browser && npm run regression:providers:list",
    "smoke:browser": "node scripts/run-browser-smoke.mjs",
    "local-agent:credential": "node scripts/update-local-agent-credential.mjs",
    "regression:providers": "node scripts/run-provider-regression.mjs",
    "regression:providers:list": "node scripts/run-provider-regression.mjs --list"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.25.12",
    "playwright-core": "^1.57.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
