# Optional local app URL used by smoke and provider regression scripts.
VIBE_OFFICE_URL=http://127.0.0.1:5180/

# Optional Chromium/Edge executable used by browser smoke checks.
VIBE_OFFICE_BROWSER=

# Optional override for local trusted registry and credential files.
# Leave blank to use the OS home directory default.
VIBE_OFFICE_LOCAL_TRUSTED_HOME=

# Optional project directories used only by browser smoke fixtures.
VIBE_OFFICE_SMOKE_PROJECT_DIR=
VIBE_OFFICE_MISSING_SMOKE_PROJECT_DIR=

# Provider regression target IDs. Use `npm run regression:providers:list` to find ready IDs.
VIBE_M9_HERMES_AGENT_ID=
VIBE_M9_DEEPSEEK_AGENT_ID=
VIBE_M9_MINIMAX_AGENT_ID=

# Local agent repair helper.
# Do not commit real keys in this file.
VIBE_AGENT_ID=
VIBE_AGENT_M9_TARGET=
VIBE_AGENT_API_KEY=
